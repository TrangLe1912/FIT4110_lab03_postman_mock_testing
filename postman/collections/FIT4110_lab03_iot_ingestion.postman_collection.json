{"info":{"_postman_id":"fit4110-lab03-iot-ingestion","name":"FIT4110 Lab03 - IoT Ingestion Contract Tests","description":"Postman Collection mẫu cho Buổi 3: Mock Server, provider-side tests, consumer-side smoke tests và Newman evidence. Cấu trúc folder bám theo bài giảng: Functional, Auth, Negative, Boundary/Reliability, Consumer-side và Local-only.","schema":"https://schema.getpostman.com/json/collection/v2.1.0/collection.json"},"event":[{"listen":"prerequest","script":{"type":"text/javascript","exec":["const prefix = pm.environment.get('tracePrefix') || 'fit4110-lab03';","pm.variables.set('traceId', prefix + '-' + Date.now());","pm.request.headers.upsert({ key: 'X-Trace-Id', value: pm.variables.get('traceId') });"]}}],"variable":[],"item":[{"name":"00_Health","item":[{"name":"GET /health - service is alive","request":{"method":"GET","header":[],"url":{"raw":"{{baseUrl}}/health","host":["{{baseUrl}}"],"path":["health"]},"description":""},"response":[],"event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('Status code is 200', function () { pm.response.to.have.status(200); });","pm.test('Response has service status', function () {","  const json = pm.response.json();","  pm.expect(json).to.have.property('status', 'ok');","  pm.expect(json).to.have.property('service');","});"]}}]}]},{"name":"01_Functional","item":[{"name":"POST /readings - happy path creates reading","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{authToken}}"}],"url":{"raw":"{{baseUrl}}/readings","host":["{{baseUrl}}"],"path":["readings"]},"description":"","body":{"mode":"raw","raw":"{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}","options":{"raw":{"language":"json"}}}},"response":[],"event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('Status code is 201', function () { pm.response.to.have.status(201); });","pm.test('Response has created reading fields', function () {","  const json = pm.response.json();","  pm.expect(json).to.have.property('reading_id');","  pm.expect(json).to.have.property('device_id');","  pm.expect(json).to.have.property('metric', 'temperature');","  pm.expect(json).to.have.property('accepted', true);","});"]}}]},{"name":"GET /readings/latest - list latest readings","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{authToken}}"}],"url":{"raw":"{{baseUrl}}/readings/latest?device_id=ESP32-LAB-A01&limit=5","host":["{{baseUrl}}"],"path":["readings","latest"],"query":[{"key":"device_id","value":"ESP32-LAB-A01"},{"key":"limit","value":"5"}]},"description":""},"response":[],"event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('Status code is 200', function () { pm.response.to.have.status(200); });","pm.test('Response contains items array', function () {","  const json = pm.response.json();","  pm.expect(json).to.have.property('items');","  pm.expect(json.items).to.be.an('array');","});"]}}]}]},{"name":"02_Auth","item":[{"name":"GET /readings/latest - valid token is accepted","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{authToken}}"}],"url":{"raw":"{{baseUrl}}/readings/latest?limit=1","host":["{{baseUrl}}"],"path":["readings","latest"]},"description":""},"response":[],"event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('Valid token request returns success', function () {","  pm.expect(pm.response.code).to.eql(200);","});"]}}]},{"name":"POST /readings - missing token is rejected on real service","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"url":{"raw":"{{baseUrl}}/readings","host":["{{baseUrl}}"],"path":["readings"]},"description":"Auth test thật: không dùng Prefer: code=401. Khi chạy trên mock, test được skip có kiểm soát vì Prism không chứng minh auth thật.","body":{"mode":"raw","raw":"{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}","options":{"raw":{"language":"json"}}}},"response":[],"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const env = pm.environment.get('env') || 'mock';","if (env === 'mock') {","  pm.test('Skipped on mock: Prism does not enforce real auth without a service implementation', function () {","    pm.expect(true).to.eql(true);","  });","} else {","  pm.test('Missing token returns 401 or 403', function () {","    pm.expect([401, 403]).to.include(pm.response.code);","  });","}"]}}]},{"name":"POST /readings - invalid token is rejected on real service","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer invalid-token"}],"url":{"raw":"{{baseUrl}}/readings","host":["{{baseUrl}}"],"path":["readings"]},"description":"Auth test thật: service local phải tự từ chối token sai.","body":{"mode":"raw","raw":"{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}","options":{"raw":{"language":"json"}}}},"response":[],"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const env = pm.environment.get('env') || 'mock';","if (env === 'mock') {","  pm.test('Skipped on mock: invalid token requires real auth middleware', function () {","    pm.expect(true).to.eql(true);","  });","} else {","  pm.test('Invalid token returns 401 or 403', function () {","    pm.expect([401, 403]).to.include(pm.response.code);","  });","}"]}}]}]},{"name":"03_Negative","item":[{"name":"POST /readings - missing required field returns validation error","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{authToken}}"},{"key":"Prefer","value":"code=400"}],"url":{"raw":"{{baseUrl}}/readings","host":["{{baseUrl}}"],"path":["readings"]},"description":"Prefer: code=400 chỉ giúp Prism chọn response lỗi theo contract; service thật phải tự validate payload.","body":{"mode":"raw","raw":"{\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}","options":{"raw":{"language":"json"}}}},"response":[],"event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('Invalid payload returns client error', function () {","  pm.expect([400, 422]).to.include(pm.response.code);","});","pm.test('Error response follows ProblemDetails shape', function () {","  const json = pm.response.json();","  pm.expect(json).to.have.property('title');","  pm.expect(json).to.have.property('status');","  pm.expect(json.status).to.be.within(400, 599);","});"]}}]},{"name":"POST /readings - wrong enum value returns validation error","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{authToken}}"},{"key":"Prefer","value":"code=400"}],"url":{"raw":"{{baseUrl}}/readings","host":["{{baseUrl}}"],"path":["readings"]},"description":"Negative test cho enum ngoài contract.","body":{"mode":"raw","raw":"{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temp_hot\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}","options":{"raw":{"language":"json"}}}},"response":[],"event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('Wrong metric enum returns client error', function () {","  pm.expect([400, 422]).to.include(pm.response.code);","});","pm.test('Error response has detail', function () {","  const json = pm.response.json();","  pm.expect(json).to.have.property('detail');","});"]}}]}]},{"name":"04_Boundary_Reliability","item":[{"name":"POST /readings - boundary value 80 is accepted","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{authToken}}"}],"url":{"raw":"{{baseUrl}}/readings","host":["{{baseUrl}}"],"path":["readings"]},"description":"","body":{"mode":"raw","raw":"{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 80,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}","options":{"raw":{"language":"json"}}}},"response":[],"event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('Boundary value at max returns success', function () {","  pm.expect(pm.response.code).to.eql(201);","});","pm.test('Response confirms accepted reading', function () {","  const json = pm.response.json();","  pm.expect(json).to.have.property('accepted', true);","});"]}}]},{"name":"POST /readings - value 81 is rejected as out of range","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{authToken}}"},{"key":"Prefer","value":"code=400"}],"url":{"raw":"{{baseUrl}}/readings","host":["{{baseUrl}}"],"path":["readings"]},"description":"Boundary test đúng phải kiểm response. Không kiểm lại request body đã gửi.","body":{"mode":"raw","raw":"{\n  \"device_id\": \"ESP32-LAB-A01\",\n  \"metric\": \"temperature\",\n  \"value\": 81,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}","options":{"raw":{"language":"json"}}}},"response":[],"event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('Out-of-range value returns client error', function () {","  pm.expect([400, 422]).to.include(pm.response.code);","});","pm.test('Boundary test checks response, not request body', function () {","  const json = pm.response.json();","  pm.expect(json).to.have.property('status');","  pm.expect(json.status).to.be.within(400, 599);","});"]}}]},{"name":"GET /readings/latest - limit above max is rejected","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{authToken}}"},{"key":"Prefer","value":"code=400"}],"url":{"raw":"{{baseUrl}}/readings/latest?limit=101","host":["{{baseUrl}}"],"path":["readings","latest"],"query":[{"key":"limit","value":"101"}]},"description":""},"response":[],"event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('Limit above max returns client error', function () {","  pm.expect([400, 422]).to.include(pm.response.code);","});"]}}]}]},{"name":"05_Consumer_side_Smoke","item":[{"name":"Consumer smoke - Camera/Core can call AI Vision mock","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{authToken}}"}],"url":{"raw":"{{aiVisionMockUrl}}/detect","host":["{{aiVisionMockUrl}}"],"path":["detect"]},"description":"Consumer-side smoke test: gọi mock của service phụ thuộc, không gọi lại API của chính mình.","body":{"mode":"raw","raw":"{\n  \"camera_id\": \"CAM01\",\n  \"image_url\": \"https://example.com/frame.jpg\"\n}","options":{"raw":{"language":"json"}}}},"response":[],"event":[{"listen":"test","script":{"type":"text/javascript","exec":["pm.test('Consumer receives success from provider mock', function () {","  pm.expect(pm.response.code).to.eql(200);","});","pm.test('Consumer can read detection fields', function () {","  const json = pm.response.json();","  pm.expect(json).to.have.property('detection_id');","  pm.expect(json).to.have.property('label');","  pm.expect(json).to.have.property('confidence');","  pm.expect(json.confidence).to.be.within(0, 1);","});"]}}]}]},{"name":"06_Local_only_NonFunctional","item":[{"name":"POST /readings - local response time threshold","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{authToken}}"}],"url":{"raw":"{{baseUrl}}/readings","host":["{{baseUrl}}"],"path":["readings"]},"description":"Latency/SLA chỉ có ý nghĩa khi chạy service thật.","body":{"mode":"raw","raw":"{\n  \"device_id\": \"ESP32-LAB-A02\",\n  \"metric\": \"humidity\",\n  \"value\": 55.2,\n  \"unit\": \"percent\",\n  \"timestamp\": \"2026-05-13T08:31:00+07:00\"\n}","options":{"raw":{"language":"json"}}}},"response":[],"event":[{"listen":"test","script":{"type":"text/javascript","exec":["const env = pm.environment.get('env') || 'mock';","if (env === 'local') {","  pm.test('Local service responds under 1000ms', function () {","    pm.expect(pm.response.responseTime).to.be.below(1000);","  });","} else {","  pm.test('Skipped on mock: mock latency is not evidence of real service reliability', function () {","    pm.expect(true).to.eql(true);","  });","}"]}}]}]}]}